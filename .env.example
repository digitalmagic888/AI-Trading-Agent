# Default safety posture. Demo and tests do not require real credentials.
LIVE_TRADING=false
FLASH_LOAN_EXECUTION=false
MAX_TRADE_USD=0
MAX_DAILY_NOTIONAL_USD=0
KILL_SWITCH=true
NETWORK=bsc-testnet
CHAIN_ALLOWLIST=bnb
TOKEN_ALLOWLIST=WBNB,BNB,USDT,USDC,CAKE,TWT

# CMC MCP can run in mock mode or call the official default MCP endpoint with an env key.
CMC_MODE=mock
CMC_MCP_URL=https://mcp.coinmarketcap.com/mcp
CMC_MCP_API_KEY=
CMC_SKILL_RESULTS_FILE=

# Trust Wallet Agent Kit / TWAK. Do not commit real values.
TWAK_MODE=mock
TRUST_WALLET_ACCESS_ID=
TRUST_WALLET_HMAC_SECRET=

# Optional chain endpoints. Do not commit private RPC secrets.
BSC_RPC_URL=
AAVE_POOL_ADDRESSES_PROVIDER=
PANCAKESWAP_ROUTER=
SECONDARY_DEX_ROUTER=

# BNB Agent service. Do not commit private keys or passwords.
ERC8183_AGENT_URL=http://localhost:8003
PRIVATE_KEY=
WALLET_PASSWORD=
