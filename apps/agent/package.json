{
  "name": "@tristack/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "demo:dry-run": "tsx src/demo/dryRun.ts",
    "demo:replay": "tsx src/demo/replay.ts",
    "contracts:deploy": "tsx src/live/deployContracts.ts",
    "wallet:fund-hot": "tsx src/live/fundHotWallet.ts",
    "worker:once": "tsx src/live/executionWorker.ts --once",
    "worker:run": "tsx src/live/executionWorker.ts",
    "broadcast:oneshot": "tsx src/live/broadcastOneShot.ts",
    "broadcast:disable": "tsx src/live/disableBroadcast.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "ethers": "6.15.0",
    "solc": "0.8.30"
